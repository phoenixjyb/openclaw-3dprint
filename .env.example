# ── Bot mode ─────────────────────────────────────────
# "feishu" (HTTP API + Feishu messaging) or "telegram" or "dual" (Telegram + HTTP API)
BOT_MODE=feishu

# ── Telegram (if BOT_MODE=telegram or dual) ──────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER_IDS=

# ── Feishu (if BOT_MODE=feishu or dual) ──────────────
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_CHAT_ID=
# FEISHU_API_PORT=8765

# ── LLM (OpenAI-compatible: OpenAI, xAI/Grok, etc.) ─
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.x.ai/v1
OPENAI_MODEL=grok-3

# ── 3D Model Generation ─────────────────────────────
MESH_PROVIDER=tripo
TRIPO_API_KEY=your-tripo-api-key
# MESHY_API_KEY=  (alternative provider)

# ── Slicer ───────────────────────────────────────────
# "local" = PrusaSlicer/OrcaSlicer on this machine (default, Mac-friendly)
# "remote" = Bambu Studio CLI on a remote Windows PC via SSH
SLICER_MODE=local
SLICER_PATH=/Applications/PrusaSlicer.app/Contents/MacOS/PrusaSlicer
# For remote mode:
# SLICER_MODE=remote
# WINDOWS_HOST=192.168.x.x
# WINDOWS_USER=your-user
# WINDOWS_SSH_KEY=~/.ssh/id_ed25519

# ── Bambu Printer ────────────────────────────────────
BAMBU_PRINTER_IP=192.168.x.x
BAMBU_PRINTER_SERIAL=your-printer-serial
BAMBU_PRINTER_ACCESS_CODE=your-access-code
# How to send files: "ftp" (direct FTPS, Mac-friendly) or "studio" (Bambu Studio CLI, needs Windows)
BAMBU_SEND_METHOD=ftp

# ── Local staging directory ──────────────────────────
# STAGING_DIR=~/.openclaw-3dprint/staging
