# ╔══════════════════════════════════════════════════════════════╗
# ║  openclaw-3dprint — Configuration                           ║
# ║                                                              ║
# ║  Copy this file to:  ~/.openclaw-3dprint/pipeline.env        ║
# ║  Then fill in your values below.                             ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Bot mode ─────────────────────────────────────────
# How users talk to the pipeline:
#   "feishu"   — HTTP API + Feishu messaging (good for OpenClaw agent integration)
#   "telegram" — Telegram bot only
#   "dual"     — both Telegram + HTTP API at once
BOT_MODE=feishu

# ── Telegram (only if BOT_MODE=telegram or dual) ─────
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. To find your user ID: message @userinfobot on Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER_IDS=              # comma-separated, e.g. 123456,789012

# ── Feishu / Lark (only if BOT_MODE=feishu or dual) ──
# 1. Go to https://open.feishu.cn/app → Create App → get App ID & Secret
# 2. Enable "Bot" capability, add bot to a group chat
# 3. Chat ID: open the group → "..." menu → copy the chat ID (starts with oc_)
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_CHAT_ID=
# FEISHU_API_PORT=8765                    # HTTP API port for agent integration

# ── LLM (any OpenAI-compatible API) ──────────────────
# Supported: OpenAI, xAI/Grok, Anthropic (via proxy), local models, etc.
# Get an OpenAI key:    https://platform.openai.com/api-keys
# Get an xAI/Grok key:  https://console.x.ai → API Keys
# Get an Anthropic key:  https://console.anthropic.com → API Keys
# Or use any OpenAI-compatible endpoint (Ollama, LM Studio, etc.)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1   # or https://api.x.ai/v1, http://localhost:11434/v1, etc.
OPENAI_MODEL=gpt-4o                         # or grok-3, claude-3-5-sonnet, llama3, etc.

# ── 3D Model Generation ─────────────────────────────
# Tripo3D (recommended): https://www.tripo3d.ai → Dashboard → API Keys
# Meshy.ai (alternative): https://app.meshy.ai → Settings → API Keys
MESH_PROVIDER=tripo                      # "tripo" or "meshy"
TRIPO_API_KEY=your-tripo-api-key
# MESHY_API_KEY=                          # only if MESH_PROVIDER=meshy

# ── Slicer ───────────────────────────────────────────
# Local mode (default, recommended for Mac):
#   Install PrusaSlicer: brew install --cask prusa-slicer
#   The path below is the default macOS location; adjust for Linux.
# Remote mode (optional):
#   Uses Bambu Studio CLI on a Windows PC via SSH — better Bambu-specific profiles.
SLICER_MODE=local
SLICER_PATH=/Applications/PrusaSlicer.app/Contents/MacOS/PrusaSlicer
# For remote mode, uncomment these:
# SLICER_MODE=remote
# WINDOWS_HOST=192.168.x.x
# WINDOWS_USER=your-user
# WINDOWS_SSH_KEY=~/.ssh/id_ed25519

# ── Bambu Printer ────────────────────────────────────
# How to find these values:
#   PRINTER_IP:          Printer LCD → Settings → Network → IP Address
#                        Or check your router's DHCP client list.
#   PRINTER_SERIAL:      Printer LCD → Settings → Device → Serial Number
#                        Also shown in Bambu Studio → Device tab.
#   ACCESS_CODE:         Printer LCD → Settings → Network → Access Code
#                        (8-character code, e.g. "a1b2c3d4")
BAMBU_PRINTER_IP=192.168.x.x
BAMBU_PRINTER_SERIAL=your-printer-serial
BAMBU_PRINTER_ACCESS_CODE=your-access-code

# How to send files to the printer:
#   "ftp"    — direct FTPS upload + MQTT command (Mac-friendly, no extra software)
#   "studio" — Bambu Studio CLI (Windows only, needs remote mode)
BAMBU_SEND_METHOD=ftp

# ── Local staging directory ──────────────────────────
# Where temporary files (downloaded models, sliced .3mf) are stored.
# Default: ~/.openclaw-3dprint/staging
# STAGING_DIR=~/.openclaw-3dprint/staging
